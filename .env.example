# Copy this file to .env and fill in your own IDs (or set these as
# environment variables in your host, e.g. Vercel project settings).
# .env is git-ignored, so no tracking ID is ever committed.

# Google Analytics 4 measurement ID  (analytics.google.com)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity project id  (clarity.microsoft.com) - optional, for heatmaps
CLARITY_PROJECT_ID=
